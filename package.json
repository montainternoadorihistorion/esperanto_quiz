{
  "private": true,
  "scripts": {
    "build:mobile": "python3 tools/build_mobile_bundle.py",
    "version:mobile": "python3 tools/update_mobile_version.py",
    "validate:mobile-assets": "python3 tools/validate_mobile_assets.py",
    "validate:mobile-assets:quick": "python3 tools/validate_mobile_assets.py --quick",
    "test:unit": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:mobile": "node node_modules/@playwright/test/cli.js test tests/mobile-pwa.spec.js --browser=chromium",
    "test:streamlit-mobile": "node node_modules/@playwright/test/cli.js test tests/streamlit-mobile.spec.js --browser=chromium",
    "serve:mobile": "python3 -m http.server 8765"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
